<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/styles/default.css">
    <title>SkinChanger</title>

    <link rel="stylesheet" href="css/fontawesome/all.min.css">

    <link rel="stylesheet" href="css/bootstrap/bootstrap-icons.min.css">
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css">
    
</head>
<body class="bg-color">

    <!-- Modal -->
    <div class="modal fade" id="patternFloat" tabindex="-1" aria-labelledby="patternFloatLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content skin-editor-shell border-0 text-light">
                <div class="modal-body p-0 skin-editor-stage">
                    <div class="skin-editor-tag"><span id="modalWeapon">Weapon</span> | <span id="modalPaint">Paint</span></div>

                    <div class="skin-editor-sidebar">
                        <div class="skin-editor-title-row">
                            <button type="button" class="skin-editor-back" data-bs-dismiss="modal" aria-label="Close">&lt;</button>
                            <h5 class="m-0" id="patternFloatLabel">Customize</h5>
                        </div>

                        <div class="skin-editor-input-group">
                            <label for="wearPreset" class="form-label m-0">Wear</label>
                            <select id="wearPreset" class="form-select form-select-sm">
                                <option value="0.000001">Factory New</option>
                                <option value="0.07">Minimal Wear</option>
                                <option value="0.15">Field-Tested</option>
                                <option value="0.38">Well-Worn</option>
                                <option value="0.45">Battle-Scarred</option>
                                <option value="custom">Custom</option>
                            </select>
                            <div class="skin-editor-hidden-inputs">
                                <input type="range" id="floatSlider" class="slider" min="0" max="1" step="0.000001" value="0.000001">
                                <input type="number" id="float" class="form-control" min="0" max="1" step="0.000001" value="0.000001">
                            </div>
                            <p id="floatText" class="m-0 text-secondary"><%= lang.modal.patternButtons[0].longName %></p>
                        </div>

                        <div class="skin-editor-input-group">
                            <label class="form-label m-0" for="pattern"><%= lang.modal.pattern %></label>
                            <input type="number" id="pattern" class="form-control" placeholder="1 - 1000" value="0">
                        </div>

                        <div class="skin-editor-input-group">
                            <label class="form-label m-0" for="nameTag">Name tag</label>
                            <input type="text" id="nameTag" class="form-control" placeholder="Name tag" disabled>
                        </div>

                        <div class="skin-editor-inline">
                            <div class="skin-editor-input-group mb-0">
                                <label class="form-label m-0" for="stattrakEnabled">Stattrak</label>
                                <input type="checkbox" id="stattrakEnabled" class="form-check-input" disabled>
                            </div>
                            <div class="skin-editor-input-group mb-0">
                                <label class="form-label m-0" for="stattrakKills">Kills</label>
                                <input type="number" id="stattrakKills" class="form-control" placeholder="/" disabled>
                            </div>
                        </div>

                        <div id="stickerEditorHost" class="skin-editor-stickers" style="display: none;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="m-0">Stickers</h6>
                                <small class="text-secondary">Up to 5</small>
                            </div>
                            <div class="skin-editor-chip-row" data-sticker-chip-row>
                                <button type="button" class="skin-editor-chip" data-sticker-chip="0">+</button>
                                <button type="button" class="skin-editor-chip" data-sticker-chip="1">+</button>
                                <button type="button" class="skin-editor-chip" data-sticker-chip="2">+</button>
                                <button type="button" class="skin-editor-chip" data-sticker-chip="3">+</button>
                                <button type="button" class="skin-editor-chip" data-sticker-chip="4">+</button>
                            </div>

                            <div class="d-flex gap-2 mt-2">
                                <button type="button" class="btn btn-sm btn-outline-light" data-sticker-advanced-toggle>Advanced</button>
                                <button type="button" class="btn btn-sm btn-primary" data-sticker-apply>Apply</button>
                                <button type="button" class="btn btn-sm btn-outline-light" data-sticker-remove>Remove</button>
                                <button type="button" class="btn btn-sm btn-outline-warning" data-sticker-reset>Reset</button>
                            </div>
                            <div class="skin-editor-advanced mt-2" data-sticker-advanced>
                                <div class="row g-2">
                                    <div class="col-4 d-none">
                                        <select class="form-select form-select-sm" data-sticker-slot>
                                            <option value="0">Slot 1</option>
                                            <option value="1">Slot 2</option>
                                            <option value="2">Slot 3</option>
                                            <option value="3">Slot 4</option>
                                            <option value="4">Slot 5</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <input class="form-control form-control-sm" type="text" data-sticker-input="id" placeholder="Sticker ID">
                                    </div>
                                    <div class="col-4"><input class="form-control form-control-sm" type="number" step="0.01" min="0.05" max="4" data-sticker-input="scale" value="1" placeholder="Scale"></div>
                                    <div class="col-4"><input class="form-control form-control-sm" type="number" step="1" min="-180" max="180" data-sticker-input="rotation" value="0" placeholder="Rot"></div>
                                    <div class="col-4"><input class="form-control form-control-sm" type="number" step="0.01" min="0" max="1" data-sticker-input="wear" value="0" placeholder="Wear"></div>
                                    <div class="col-6"><input class="form-control form-control-sm" type="number" step="0.01" min="-2" max="2" data-sticker-input="x" value="0" placeholder="X"></div>
                                    <div class="col-6"><input class="form-control form-control-sm" type="number" step="0.01" min="-2" max="2" data-sticker-input="y" value="0" placeholder="Y"></div>
                                </div>
                            </div>
                            <div class="mt-2" data-sticker-summary></div>
                        </div>

                        <div class="skin-editor-actions">
                            <button type="button" class="btn btn-outline-light" id="applyTButton" onclick="changeParams('t')">Apply T</button>
                            <button type="button" class="btn btn-outline-light" id="applyCTButton" onclick="changeParams('ct')">Apply CT</button>
                            <button type="button" class="btn btn-outline-warning" id="applyBothButton" onclick="changeParams('both')">Apply Both</button>
                            <button type="button" class="d-none" id="modalButton"></button>
                        </div>
                    </div>

                    <div class="skin-editor-preview">
                        <img id="modalImg" class="skin-editor-preview-img" src="https://raw.githubusercontent.com/ByMykel/CSGO-API/efe25483a04a03414dea9c61d4b0e958a373cdfd/public/images/econ/default_generated/weapon_knife_gut_aa_fade_light.png" alt="Preview">
                        <div id="editor3dHost" class="skin-editor-preview-3d" style="display: none;">
                            <div id="editor3dCanvas"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Success Notification -->
    <div id="successNotification" class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999; display: none; opacity: 0; transition: opacity 0.3s ease-in-out;">
        <div class="alert alert-success mb-0 shadow" role="alert">
            <i class="bi bi-check-circle me-2"></i><strong>Success!</strong> Changes saved.
        </div>
    </div>

    <nav class="navbar navbar-dark bg-nav">
        <div class="container">
            <div class="nav-item d-flex align-items-center">
                <a class="navbar-brand" href="#"><%= config.name %></a>      
                <div class="nav-item d-flex align-items-center">
                    <% if (config.connect.show) { %>
                        <a href="steam://connect/<%= config.connect.serverIp %>:<%= config.connect.serverPort %>?appid=730&password=<%= config.connect.serverPassword %>" class="btn btn-outline-warning rounded-pill d-none d-md-block"><small><%= lang.connect %></small></a>
                    <% } %>
                </div>
            </div>
            <div class="nav-item d-flex align-items-center">
                <% if (typeof user == 'undefined') { %>
                    <a class="btn btn-primary my-2 my-sm-0 text-warning" href="api/auth/steam"><%= lang.navLogin %> <i class="bi bi-steam text-secondary ms-1"></i></a>
                <% } else { %>
                    <div class="nav-item dropdown" data-bs-theme="dark">
                        <div class="profile-bg rounded p-1 px-2 d-flex align-items-center dropdown-toggle" role="button" data-bs-toggle="dropdown">
                            <p class="m-0 me-2"><small><%= user.displayName %></small></p>
                            <img src="<%= user.photos[1].value%>" alt="" height="30" class="rounded-pill">
                        </div>
                            <ul class="dropdown-menu">
                                <% if (config.connect.show) { %>
                                    <a class="dropdown-item text-warning d-block d-md-none" href="steam://connect/<%= config.connect.serverIp %>:<%= config.connect.serverPort %>?appid=730&password=<%= config.connect.serverPassword %>"><small><%= lang.connect %></small></a>
                                <% } %>
                                <a class="dropdown-item text-danger" href="api/logout"><%= lang.navLogout %></a>
                                <a class="dropdown-item text-danger" href="api/delete"><%= lang.navDelete %></a>
                            </ul>
                       
                <% } %>
            </div>
        </div>
    </nav>

    <% if (typeof user == 'undefined') { %>
        <h5 class="text-center mt-4 text-white"><%= lang.needLogin %> <a class="text-warning" href="api/auth/steam"><%= lang.viaSteam %></a></h5>
    <% } else { %>

    <div class="container text-light mt-3">
        <div class="d-block d-lg-none list-group list-group-horizontal position-relative overflow-auto d-flex justify-content-between bg-nav p-2 rounded">
            <button onclick="showKnives()" id="sideBtnKnives" class="btn btn-primary d-flex my-1 mx-1 align-items-center">
                <img src="icons/weapon_knife_karambit.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.knives %></small></p>
            </button>

            <button onclick="showPistols()" id="sideBtnPistols" class="btn btn-primary d-flex my-1 mx-1 align-items-center">
                <img src="icons/weapon_deagle.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.pistols %></small></p>
            </button>

            <button onclick="showRifles()" id="sideBtnRifles" class="btn btn-primary d-flex my-1 mx-1 align-items-center">
                <img src="icons/weapon_ak47.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.rifles %></small></p>
            </button>

            <button onclick="showPPs()" id="sideBtnPPs" class="btn btn-primary d-flex my-1 mx-1 align-items-center">
                <img src="icons/weapon_mac10.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.SMGs %></small></p>
            </button>

            <button onclick="showShotguns()" id="sideBtnShotguns" class="btn btn-primary my-1 mx-1 d-flex align-items-center">
                <img src="icons/weapon_negev.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.heavy %></small></p>
            </button>
        </div>
        <div class="row">
            <div class="col-2 rounded p-0 d-none d-lg-block">

                <div class="bg-nav p-0 p-2 rounded">
                    <button onclick="showKnives()" id="sideBtnKnives" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <img src="icons/weapon_knife_karambit.svg" class="sideBtnImg" width="35px">
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.knives %></small></p>
                    </button>

                    <button onclick="showGloves()" id="sideBtnGloves" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <i class="fa-solid fa-mitten ms-2 me-2 my-auto sideBtnI"></i>
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.gloves %></small></p>
                    </button>


                    <button onclick="showPistols()" id="sideBtnPistols" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <img src="icons/weapon_deagle.svg" class="sideBtnImg" width="35px">
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.pistols %></small></p>
                    </button>
    
                    <button onclick="showRifles()" id="sideBtnRifles" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <img src="icons/weapon_ak47.svg" class="sideBtnImg" width="35px">
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.rifles %></small></p>
                    </button>
    
                    <button onclick="showPPs()" id="sideBtnPPs" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <img src="icons/weapon_mac10.svg" class="sideBtnImg" width="35px">
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.SMGs %></small></p>
                    </button>
    
                    <button onclick="showShotguns()" id="sideBtnShotguns" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <img src="icons/weapon_negev.svg" class="sideBtnImg" width="35px">
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.heavy %></small></p>
                    </button>

                    <button onclick="showUtility()" id="sideBtnUtility" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <i class="fa-solid fa-bomb ms-2 me-2 my-auto sideBtnI"></i>
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.utility %></small></p>
                    </button>

                    <button onclick="showCTAgents()" id="sideBtnCTAgents" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <i class="fa-solid fa-person-rifle ms-2 me-2 my-auto sideBtnI"></i>
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.ctAgents %></small></p>
                    </button>
                    
                    <button onclick="showTAgents()" id="sideBtnTAgents" class="btn btn-primary w-100 d-flex mb-2 align-items-center">
                        <i class="fa-solid fa-person-rifle ms-2 me-2 my-auto sideBtnI"></i>
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.tAgents %></small></p>
                    </button>

                    <button onclick="showMusic()" id="sideBtnMusic" class="btn btn-primary w-100 d-flex align-items-center">
                        <i class="fa-solid fa-music ms-2 me-2 my-auto sideBtnI"></i>
                        <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.musicKits %></small></p>
                    </button>
                </div>

            </div>
            <div class="col-mb-12 col-lg-10 mb-5">
                <div class="bg-nav p-3 rounded mb-3 d-flex justify-content-start" id="navToolbar">
                    <button type="button" class="btn btn-outline-primary" id="backBtn" onclick="goBack()" style="display: none;">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </button>
                </div>
                <div class="row" id="skinsContainer">
                    <h3 class="text-center mt-5"><%= lang.selectCategory %></h3>

                </div>
            </div>
        </div>
    </div>
    <% } %>
    
    <!-- Filler for footer -->
    <div class="container-fluid py-3">
        <p class="m-0"> </p>
        <p class="m-0"> </p>
    </div>

    <div class="container-fluid fixed-bottom bg-nav text-light text-center py-3">
        <p class="text-decoration-none text-light m-0"><%= config.name %> | <%= new Date().getFullYear();%> </p>
        
        <!-- Please don't change this -->
        <p class="m-0 text-secondary">Made by <a href="https://github.com/L1teD" class="text-secondary">L1te</a> @ <a href="https://github.com/L1teD/cs2-WeaponPaints-website" class="text-secondary">cs2-WeaponPaints-website</a></p>
    </div>

</body>

<script src="js/bootstrap/bootstrap.bundle.min.js"></script>

<script src="socket.io/socket.io.js"></script>
<script>
    window.appConfig = <%- JSON.stringify(config) %>;
</script>
<script src="js/renderer3d.contract.js"></script>
<script src="js/renderer3d.js"></script>
<script src="js/stickerEditor.js"></script>
<script src="js/index.js"></script>

<script type="module" src="js/templates.js"></script>
<script type="module" src="js/sideBtns.js"></script>


<script>
    let lang = "<%- config.lang %>";
    let langObject = <%- JSON.stringify(lang) %>; 
    let selectedKnife = {
        knife: undefined,
        steamid: undefined,
    }
    let selectedKnives = []
    let selectedSkins = []
    let selectedGloves = {
        weapon_defindex: undefined,
        steamid: undefined,
    }
    let selectedAgents = {
        agent_ct: undefined,
        agent_t: undefined,
        steamid: undefined,
    }
    let selectedMusic = {
        music_id: undefined,
        steamid: undefined,
    }
</script>


<% if (typeof knife != 'undefined') { %>
    <script>    
        selectedKnives = <%- JSON.stringify(knives) %>;
        selectedKnife = <%- JSON.stringify(knife) %>;
    </script>
<% } %>

<% if (typeof skins != 'undefined') { %>
    <script>    
        selectedSkins = <%- JSON.stringify(skins) %>;
    </script>
<% } %>

<% if (typeof gloves != 'undefined') { %>
    <script>
        selectedGloves = <%- JSON.stringify(gloves) %>;
    </script>
<% } %>

<% if (typeof agents != 'undefined') { %>
    <script>
        selectedAgents = <%- JSON.stringify(agents) %>;
    </script>
<% } %>

<% if (typeof music != 'undefined') { %>
    <script>
        selectedMusic = <%- JSON.stringify(music) %>;
    </script>
<% } %>

<% if (typeof user != 'undefined') { %>
    <script>    
        let user = <%- JSON.stringify(user) %>;
    </script>
<% } %>


<script></script>

</html>